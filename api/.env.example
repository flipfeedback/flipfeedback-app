# Copy to .env and fill in. NEVER commit a real .env (this repo is public).
# Read all config from the environment; no secrets in source.

# Postgres connection string used by Prisma.
DATABASE_URL=postgresql://flipfeedback:flipfeedback@localhost:5432/flipfeedback?schema=public

# Secret used to sign JWTs. Required in production; generate a long random value.
JWT_SECRET=replace-with-a-long-random-secret

# Optional.
PORT=4000
JWT_EXPIRES_IN=7d
# Comma-separated list of allowed SPA origins for CORS.
CORS_ORIGINS=http://localhost:5173
# Override the demo password used by the seed (defaults to demo-password-123).
# SEED_DEMO_PASSWORD=
