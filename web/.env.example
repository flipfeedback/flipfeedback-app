# Copy to .env for local dev. NEVER commit a real .env.

# Base URL the SPA uses for API calls. In dev, leaving this unset uses the Vite
# proxy at /api (-> http://localhost:4000). In a built image, the container's
# API_URL env rewrites the baked placeholder at startup.
# VITE_API_URL=http://localhost:4000

# Dev-only: where the Vite dev-server proxy forwards /api.
# VITE_API_PROXY=http://localhost:4000
